# Copy this file to deploy.env (already gitignored) and fill in the real
# values. deploy.env stays only on the machine you run the script from —
# it is never copied to the server.
#
#   cp deploy.env.example deploy.env

REMOTE_HOST=220.74.81.41
REMOTE_USER=daigeunlee
REMOTE_PORT=22
REMOTE_DIR=/opt/apollon-postgresql

# Leave empty to be prompted for the password securely at runtime instead
# of storing it in this file.
REMOTE_PASS=

# --- Used by deploy_git_clone.sh only ---
# Repo is cloned to ${REMOTE_DIR}/${CLONE_DIR_NAME}, e.g.
# /opt/apollon-postgresql/postgresql
REPO_URL=https://github.com/raphaellee-waikorea/apollon-aegis-postgresql.git
CLONE_DIR_NAME=postgresql
REPO_BRANCH=main

# Only needed if the repo above is private. A GitHub personal access token
# (fine-grained, contents:read is enough) gets embedded into the clone URL
# for non-interactive access. Leave empty for a public repo.
GIT_TOKEN=
